<UserControl x:Class="DemExam.Desktop.Views.CreateEditUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DemExam.Desktop.Views"
             xmlns:controls="clr-namespace:DemExam.Desktop.Controls"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel MaxWidth="300">
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"></TextBlock>

            <StackPanel Margin="10">
                <controls:InputControl Caption="Фамилия:" Text="{Binding User.LastName}" Margin="5" />
                <controls:InputControl Caption="Имя:" Text="{Binding User.FirstName}" Margin="5" />
                <controls:InputControl Caption="Отчество:" Text="{Binding User.Patronymic}" Margin="5" />
                <controls:InputControl Caption="Логин:" Text="{Binding User.Login}" Margin="5" />
                <controls:InputControl Caption="Пароль:" Text="{Binding User.Password}" Margin="5" />
                
                <TextBlock Text="Роль" Margin="5,10,5,0"></TextBlock>
                <ComboBox ItemsSource="{Binding Roles}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedRole}"
                          Margin="5"></ComboBox>
                
                <TextBlock Text="Статус" Margin="5,10,5,0" />
                <ComboBox ItemsSource="{Binding Statuses}" 
                          DisplayMemberPath="Name" 
                          SelectedItem="{Binding SelectedStatus}" 
                          Margin="5" />
            </StackPanel>
            
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="5"></TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="10">
                <Button Content="Сохранить" Margin="5" Command="{Binding SaveCommand}"></Button>
                <Button Content="Закрыть" Margin="5" Command="{Binding CancelCommand}"></Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>